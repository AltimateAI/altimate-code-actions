diff --git a/models/marts/fct_completed_orders.sql b/models/marts/fct_completed_orders.sql
new file mode 100644
index 0000000..f7g8h9i
--- /dev/null
+++ b/models/marts/fct_completed_orders.sql
@@ -0,0 +1,22 @@
+with orders as (
+    select * from {{ ref('stg_orders') }}
+),
+
+payments as (
+    select * from {{ ref('stg_payments') }}
+),
+
+final as (
+    select
+        orders.order_id,
+        orders.customer_id,
+        orders.order_date,
+        orders.order_status,
+        coalesce(payments.total_amount, 0) as order_total
+    from orders
+    left join payments on orders.order_id = payments.order_id
+    where orders.order_status = 'completed'
+)
+
+select * from final
