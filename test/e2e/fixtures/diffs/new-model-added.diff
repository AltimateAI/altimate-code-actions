diff --git a/models/marts/dim_products.sql b/models/marts/dim_products.sql
new file mode 100644
index 0000000..a1b2c3d
--- /dev/null
+++ b/models/marts/dim_products.sql
@@ -0,0 +1,35 @@
+{{
+    config(
+        materialized='table',
+        unique_key='product_id'
+    )
+}}
+
+with products as (
+    select * from {{ ref('stg_products') }}
+),
+
+categories as (
+    select * from {{ ref('stg_categories') }}
+),
+
+final as (
+    select
+        p.product_id,
+        p.product_name,
+        p.sku,
+        c.category_name,
+        c.parent_category_name,
+        p.unit_price,
+        p.cost_price,
+        p.unit_price - p.cost_price as margin,
+        case
+            when p.unit_price - p.cost_price > 0 then 'profitable'
+            when p.unit_price - p.cost_price = 0 then 'break-even'
+            else 'loss'
+        end as margin_status,
+        p.is_active,
+        p.created_at,
+        p.updated_at
+    from products p
+    left join categories c on p.category_id = c.category_id
+)
+
+select * from final
