diff --git a/models/marts/fct_orders.sql b/models/marts/fct_orders.sql
index d5e6f7g..k8l9m0n 100644
--- a/models/marts/fct_orders.sql
+++ b/models/marts/fct_orders.sql
@@ -1,3 +1,9 @@
+{{
+    config(
+        materialized='incremental',
+        unique_key='order_id'
+    )
+}}
+
 with orders as (
     select * from {{ ref('stg_orders') }}
 ),
@@ -12,7 +18,13 @@ final as (
         orders.customer_id,
         orders.order_date,
         orders.order_status,
-        coalesce(payments.total_amount, 0) as order_total
+        orders.batch_id,
+        coalesce(payments.total_amount, 0) as order_total,
+        payments.payment_method,
+        payments.currency
     from orders
     left join payments on orders.order_id = payments.order_id
+    {% if is_incremental() %}
+    where orders.loaded_at > (select max(loaded_at) from {{ this }})
+    {% endif %}
 )

